# Заповніть порожні поля перед першим запуском — API відмовиться стартувати без них.
#   JWT_SECRET=$(openssl rand -base64 48)
#   ADMIN_PASSWORD=$(openssl rand -base64 18)
#   POSTGRES_PASSWORD=$(openssl rand -base64 24)
# POSTGRES_PASSWORD читається лише під час першої ініціалізації бази.

POSTGRES_DB=richstudio
POSTGRES_USER=richstudio
POSTGRES_PASSWORD=
DB_SCHEMA=richstudio_v11_2
REDIS_URL=redis://redis:6379/0
JWT_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=low
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TEXT_MODELS=gpt-5-mini,gpt-5,gpt-4.1-mini,gpt-4.1,gpt-4o-mini,gpt-4o
OPENAI_IMAGE_MODELS=gpt-image-2,gpt-image-1,gpt-image-1-mini
TEXT_PRICING_JSON={"gpt-4.1-mini":{"input":0.4,"output":1.6},"gpt-4.1":{"input":2.0,"output":8.0},"gpt-4o-mini":{"input":0.15,"output":0.6},"gpt-4o":{"input":2.5,"output":10.0},"gpt-5-mini":{"input":0.25,"output":2.0},"gpt-5":{"input":1.25,"output":10.0}}
IMAGE_PRICING_JSON={"gpt-image-1":{"low":0.02,"medium":0.07,"high":0.19},"gpt-image-1-mini":{"low":0.005,"medium":0.015,"high":0.04},"gpt-image-2":{"low":0.02,"medium":0.06,"high":0.2}}
MEDIA_DIR=/app/media
# transitional | strict — підписані посилання на зображення
MEDIA_SIGNING=transitional
# Вхід через GitHub (опційно). Створіть OAuth App: github.com/settings/developers,
# Authorization callback URL: http://SERVER_IP:3000/api/auth/github/callback
# (або https://ваш-домен/... - тоді задайте GITHUB_CALLBACK_URL явно).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=
# shared - усі редагують усі проєкти; owner - змінює лише власник проєкту або admin
PROJECT_OWNERSHIP=shared
REQUEST_TIMEOUT_SECONDS=75
STUCK_PROJECT_MINUTES=45
# Денна стеля витрат на AI у доларах; 0 — вимкнено
DAILY_BUDGET_USD=25
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=
# Домен для HTTPS (профіль tls): наприклад studio.example.com. Без нього профіль не стартує.
PUBLIC_DOMAIN=
